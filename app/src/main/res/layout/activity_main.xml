<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="12dp">

    <!-- Barre du haut -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/hint_rechercher"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_search_rounded"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="#1A1A1A"
            android:textColorHint="#9A9A9A"
            android:textSize="15sp"
            android:textCursorDrawable="@null"
            android:imeOptions="actionSearch" />

        <TextView
            android:id="@+id/tvNoteCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/topBar"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:textSize="12sp"
            android:textColor="#828282"
            android:textStyle="italic" />

        <Button
            android:id="@+id/btnFavoris"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="@string/btn_favoris"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="@color/app_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSort"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text=""
            app:icon="@drawable/ic_sort"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            app:iconTint="@color/app_text"
            android:contentDescription="@string/btn_trier" />
    </LinearLayout>

    <!-- Aucune notes -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/txt_aucune_notes"
        android:textSize="16sp"
        android:textColor="#828282"
        android:visibility="gone" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:layout_above="@id/fabAdd"
        android:layout_marginBottom="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Palette de couleurs : 6 couleurs uniquement -->
    <LinearLayout
        android:id="@+id/colorPaletteLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="72dp"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_palette_rounded"
        android:elevation="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <ImageView android:id="@+id/colorGray"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_gray"
            android:contentDescription="Gris" />

        <ImageView android:id="@+id/colorGreen"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_green"
            android:contentDescription="Vert" />

        <ImageView android:id="@+id/colorRed"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_red"
            android:contentDescription="Rouge" />

        <ImageView android:id="@+id/colorBlue"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_blue"
            android:contentDescription="Bleu" />

        <ImageView android:id="@+id/colorYellow"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle_yellow"
            android:contentDescription="Jaune" />

        <ImageView android:id="@+id/colorOrange"
            android:layout_width="40dp" android:layout_height="40dp"
            android:background="@drawable/circle_orange"
            android:contentDescription="Orange" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="4dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Ajouter une note"
        app:backgroundTint="#000000"
        app:tint="#FFFFFF" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabTheme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="4dp"
        android:src="@drawable/ic_moon"
        android:contentDescription="Changer de thème"
        app:backgroundTint="#000000"
        app:tint="#FFFFFF" />
</RelativeLayout>